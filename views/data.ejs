<%- include("_header") -%>
<h1>Books</h1>
<% if (message !== "success") { %>
  <h2>We Encountered an Error</h2>
  <p><%= message %></p>
<% } else { %>
  <p><a class="btn btn-success" href="/books/add">Add a Book</a></p>
  <table class="table">
    <thead class="thead-dark">
      <tr>
        <th scope="col">ID</th>
        <th scope="col">Title</th>
        <th scope="col">Author</th>
        <th scope="col">Comments</th>
        <th scope="col">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% model.forEach(book => { %>
        <tr>
          <td><%= book.id %></td>
          <td><%= book.title %></td>
          <td><%= book.author %></td>
          <td><%= book.comments %></td>
          <td>
            <a class="btn btn-sm btn-primary" href="/books/edit/<%= book.id %>">Edit</a>
            <form style="display:inline" action="/books/delete/<%= book.id %>" method="post" onsubmit="return confirm('Delete this book?');">
              <button class="btn btn-sm btn-danger" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
<%- include("_footer") -%>
